# Server
PORT=3001

# University dataset path relative to backend root, or absolute path
# Default: data/universities.json
DATA_PATH=data/universities.json

# Optional: set NODE_ENV=development for verbose logging
NODE_ENV=development

# Enable AI-powered analyzers (true = use OpenAI when key is set; false = rule-based only)
USE_AI_ANALYZERS=false

# OpenAI API key. Required for AI analyzers when USE_AI_ANALYZERS=true. Use quotes if the value contains hyphens or special chars. Leave blank to fall back to rule-based.
OPENAI_API_KEY=
